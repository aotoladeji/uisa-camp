# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=uisa_user
DB_PASSWORD=Network_admin
DB_NAME=uisa_camp
DB_SCHEMA=uisa_app
DB_SSL=false

# ─── JWT ──────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h

# ─── File Uploads ─────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── Email (Nodemailer) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=uisportsacademy@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="UI Sports Academy <uisportsacademy@gmail.com>"

# ─── Camp Details ─────────────────────────────
CAMP_FEE=230000
EARLY_BIRD_DISCOUNT=10
EARLY_BIRD_DEADLINE=2026-07-03
REGULAR_DEADLINE=2026-07-25
BANK_NAME="Access Bank"
BANK_ACCOUNT=1805832892
BANK_ACCOUNT_NAME="University of Ibadan MacArthur Grants"

# ─── Frontend URL (CORS) ──────────────────────
CLIENT_URL=http://localhost:3000
